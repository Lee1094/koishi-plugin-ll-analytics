{
  "name": "koishi-plugin-ll-analytics",
  "version": "1.8.0",
  "description": "自定义数据统计：消息量、指令调用、关键词触发（WebUI显示）",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": ["lib", "dist"],
  "scripts": {
    "build": "tsc",
    "build:client": "esbuild client/index.ts --bundle --format=esm --external:vue --external:@koishijs/client --outfile=dist/index.js",
    "clean": "rimraf lib dist"
  },
  "author": "lee",
  "license": "MIT",
  "keywords": ["koishi", "koishi-plugin", "analytics"],
  "koishi": {
    "description": { "zh": "数据统计：消息量/指令/关键词触发排行，WebUI横向柱状图" },
    "service": { "required": ["console"], "optional": ["database"] }
  },
  "peerDependencies": {
    "@koishijs/plugin-console": "^5.24.3",
    "koishi": "^4.16.3"
  },
  "devDependencies": {
    "@koishijs/client": "^5.24.3",
    "@koishijs/console": "^5.24.3",
    "esbuild": "^0.20.0",
    "koishi": "^4.18.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}
